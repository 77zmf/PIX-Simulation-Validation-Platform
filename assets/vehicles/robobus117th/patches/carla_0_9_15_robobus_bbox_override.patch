 #include "Carla/Actor/CarlaActorFactory.h"
 
 #include "Carla/Game/Tagger.h"
+#include "Carla/Vehicle/CarlaWheeledVehicle.h"
 #include "Carla/Vehicle/VehicleControl.h"
 
+#include "Components/BoxComponent.h"
+
 #include "GameFramework/Controller.h"
 
+namespace
+{
+
+bool IsPixRobobus117th(const FActorDescription &Description)
+{
+  return Description.Id == TEXT("vehicle.pixmoving.robobus");
+}
+
+void ApplyPixRobobus117thBoundingBoxOverride(AActor &Actor, const FActorDescription &Description)
+{
+  if (!IsPixRobobus117th(Description))
+  {
+    return;
+  }
+
+  ACarlaWheeledVehicle *Vehicle = Cast<ACarlaWheeledVehicle>(&Actor);
+  if (!Vehicle)
+  {
+    UE_LOG(LogCarla, Warning, TEXT("PIX_ROBOBUS_BBOX_OVERRIDE skipped non-vehicle actor=%s"), *Actor.GetName());
+    return;
+  }
+
+  UBoxComponent *Bounds = Vehicle->GetVehicleBoundingBox();
+  if (!Bounds)
+  {
+    UE_LOG(LogCarla, Warning, TEXT("PIX_ROBOBUS_BBOX_OVERRIDE skipped missing VehicleBounds actor=%s"), *Actor.GetName());
+    return;
+  }
+
+  // 117th vehicle_info.param.yaml: length=3.82m, width=1.91m, height=2.209m.
+  const FVector ExtentCm(191.0f, 95.5f, 110.45f);
+  FTransform BoundsTransform;
+  BoundsTransform.SetTranslation(FVector(0.0f, 0.0f, 110.45f));
+  Bounds->SetRelativeTransform(BoundsTransform);
+  Bounds->SetBoxExtent(ExtentCm);
+  UE_LOG(LogCarla, Display, TEXT("PIX_ROBOBUS_BBOX_OVERRIDE actor=%s extent_cm=(%.2f,%.2f,%.2f) origin_cm=(0.00,0.00,110.45)"),
+      *Actor.GetName(), ExtentCm.X, ExtentCm.Y, ExtentCm.Z);
+}
+
+} // namespace
+
